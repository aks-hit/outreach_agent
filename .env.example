# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here       # aistudio.google.com/app/apikey
SPREADSHEET_ID=your_google_sheet_id_here      # from sheet URL: /d/THIS_PART/edit
SENDER_EMAIL=your.gmail@gmail.com             # Gmail you'll send from

# ── Contact Auto-Discovery (Hunter.io, Apollo.io, Snov.io) ────────────────────
# The agent tries the APIs in priority order:
# 1. Hunter.io (25 free searches/month):
#    Sign up free at https://hunter.io → API → copy key
#    HUNTER_API_KEY=your_key
# 2. Apollo.io (50 free exports/month):
#    Sign up free at https://app.apollo.io → Settings → Integrations → API Keys
#    APOLLO_API_KEY=your_key
# 3. Snov.io (50 free credits/month):
#    Sign up free at https://app.snov.io → Profile → API → copy ID + Secret
#    SNOV_CLIENT_ID=your_id
#    SNOV_CLIENT_SECRET=your_secret
# 4. Google Custom Search (100 FREE queries/day — scrapes LinkedIn profiles):
#    Step 1: https://programmablesearchengine.google.com/ → New Search Engine
#            → Sites to search: linkedin.com/in/* → Copy the "Search Engine ID"
#    Step 2: https://console.cloud.google.com/ → APIs → Custom Search API → Enable
#            → Credentials → Create API Key → copy it
#    GOOGLE_CSE_API_KEY=your_google_api_key
#    GOOGLE_CSE_ID=your_search_engine_id

# ── Optional (defaults shown) ─────────────────────────────────────────────────
YOUR_NAME=Your Full Name
YOUR_LINKEDIN=linkedin.com/in/yourprofile
YOUR_RESUME=https://link-to-your-resume.com
YOUR_COLLEGE=IIM Kashipur                 # your own college for alumni-first outreach
EMAILS_PER_DAY=10             # daily sends cap (standard Gmail limit is 500/day)
FOLLOW_UP_DAYS=5              # days before sending follow-up to non-repliers
HUNTER_MAX_SEARCHES=100       # max companies to search across APIs per daily run

# ── LinkedIn Scraper (Playwright) ─────────────────────────────────────────────
# The agent uses Playwright to scroll your LinkedIn feed and discover hiring posts.
# First run opens a browser for manual login. Session is saved for future headless runs.
LINKEDIN_ENABLED=true                  # set to false to disable LinkedIn scraping
LINKEDIN_MAX_POSTS=20                  # max posts to scrape per daily run
# LINKEDIN_SEARCH_KEYWORDS=hiring AI engineer,looking for ML engineer,open role software

