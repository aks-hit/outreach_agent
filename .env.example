# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here       # aistudio.google.com/app/apikey
SPREADSHEET_ID=your_google_sheet_id_here      # from sheet URL: /d/THIS_PART/edit
SENDER_EMAIL=your.gmail@gmail.com             # Gmail you'll send from

# ── Contact Auto-Discovery (Hunter.io, Apollo.io, Snov.io) ────────────────────
# The agent tries the APIs in priority order:
# 1. Hunter.io (25 free searches/month):
#    Sign up free at https://hunter.io → API → copy key
#    HUNTER_API_KEY=your_key
# 2. Apollo.io (50 free exports/month):
#    Sign up free at https://app.apollo.io → Settings → Integrations → API Keys
#    APOLLO_API_KEY=your_key
# 3. Snov.io (50 free credits/month):
#    Sign up free at https://app.snov.io → Profile → API → copy ID + Secret
#    SNOV_CLIENT_ID=your_id
#    SNOV_CLIENT_SECRET=your_secret

# ── Optional (defaults shown) ─────────────────────────────────────────────────
YOUR_NAME=Akshit Singh
YOUR_LINKEDIN=linkedin.com/in/akshitsingh-007
EMAILS_PER_DAY=450            # daily sends cap (standard Gmail limit is 500/day)
FOLLOW_UP_DAYS=5              # days before sending follow-up to non-repliers
HUNTER_MAX_SEARCHES=100       # max companies to search across APIs per daily run
